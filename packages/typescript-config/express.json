{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ExpressJS Server",
  "compilerOptions": {
    "target": "ES2022",
    "verbatimModuleSyntax": false,
    "module": "NodeNext",
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "removeComments": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  }
}
